#!/bin/bash
# Sensitive Guard - 命令包装器

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$SCRIPT_DIR/lib/core.sh"

init_guard

if [ "$(basename "$0")" = "sless" ]; then
  file="$1"
  if [ -f "$file" ]; then
    desensitize_content "$(cat "$file")" | less
  else
    less "$@"
  fi
fi
